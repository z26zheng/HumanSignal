{
  "name": "human-signal",
  "description": "Signal intelligence for LinkedIn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "eval:rules": "tsx -r tsconfig-paths/register scripts/evaluate-rules.ts",
    "perf:baseline": "tsx -r tsconfig-paths/register scripts/perf-baseline.ts",
    "release:check-package": "tsx scripts/check-package-size.ts",
    "manual-test": "bash scripts/manual-test.sh",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@preact/preset-vite": "2.10.5",
    "@types/jsdom": "28.0.1",
    "jsdom": "29.1.1",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5",
    "wxt": "0.20.25"
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
  "dependencies": {
    "preact": "10.29.1"
  }
}
